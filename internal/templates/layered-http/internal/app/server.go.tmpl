package app

import (
	"context"
	"net/http"
[[- if .HasDatabase ]]

	"[[ .ModulePath ]]/internal/repository"
[[- end ]]
	"[[ .ModulePath ]]/internal/service"
	httphandler "[[ .ModulePath ]]/internal/transport/http"
)

// initHTTPServer wires the dependency chain and creates the *http.Server.
func (a *App) initHTTPServer() error {
[[- if .HasDatabase ]]
	repo := repository.NewResourceRepository(a.DB)
	svc := service.NewResourceService(repo)
	handler := httphandler.NewHandler(svc, a.DB, a.Config.OTel.Enabled)
[[- else ]]
	svc := service.NewResourceService(nil)
	handler := httphandler.NewHandler(svc, nil, a.Config.OTel.Enabled)
[[- end ]]

	a.HTTPServer = &http.Server{
		Addr:         a.Config.HTTP.Addr(),
		Handler:      handler,
		ReadTimeout:  a.Config.HTTP.ReadTimeout,
		WriteTimeout: a.Config.HTTP.WriteTimeout,
		IdleTimeout:  a.Config.HTTP.IdleTimeout,
	}

	a.onShutdown(func(ctx context.Context) error {
		return a.HTTPServer.Shutdown(ctx)
	})

	return nil
}
