BINARY   := [[ .ProjectName ]]
PKG      := ./cmd/app
GOFLAGS  := -ldflags="-s -w"
TOOLS_BIN := tools/bin

.PHONY: build run test lint[[ if .HasMigrations ]] migrate-up migrate-down[[ end ]][[ if .HasDBTooling ]] generate[[ end ]][[ if .HasContainer ]] docker-build docker-run[[ end ]] clean tools help[[ if .HasContainer ]] check-docker[[ end ]]

## build: compile the service binary
build:
	go build $(GOFLAGS) -o $(BINARY) $(PKG)

## run: build and run the service
run: build
	./$(BINARY)

## test: run tests with race detector
test:
	go test -race -v -count=1 ./...

## lint: run golangci-lint (project-local binary)
lint: $(TOOLS_BIN)/golangci-lint
	$(TOOLS_BIN)/golangci-lint run ./...
[[ if .HasMigrations ]]
## migrate-up: apply database migrations
migrate-up: $(TOOLS_BIN)/goose
	$(TOOLS_BIN)/goose -dir migrations postgres "$$DATABASE_URL" up

## migrate-down: roll back the last migration
migrate-down: $(TOOLS_BIN)/goose
	$(TOOLS_BIN)/goose -dir migrations postgres "$$DATABASE_URL" down
[[ end -]]
[[ if .HasDBTooling ]]
## generate: regenerate sqlc query code
generate: $(TOOLS_BIN)/sqlc
	$(TOOLS_BIN)/sqlc generate
[[ end -]]
[[ if .HasContainer ]]
## docker-build: build the Docker image
docker-build: check-docker
	docker build -t $(BINARY):latest .

## docker-run: build and run the Docker image
docker-run: docker-build
	docker run --rm -p 8080:8080 -p 9090:9090 --env-file .env $(BINARY):latest
[[ end ]]
## clean: remove build artifacts and test cache
clean:
	rm -f $(BINARY)
	go clean -testcache

## tools: build all development tools into tools/bin/
tools: tools-tidy $(TOOLS_BIN)/golangci-lint[[ if .HasMigrations ]] $(TOOLS_BIN)/goose[[ end ]][[ if .HasDBTooling ]] $(TOOLS_BIN)/sqlc[[ end ]]
	@echo "Tools built to $(TOOLS_BIN)/"

.PHONY: tools-tidy
tools-tidy:
	@test -f tools/go.sum || (cd tools && go mod tidy)

$(TOOLS_BIN)/golangci-lint: tools/go.mod tools/tools.go
	@mkdir -p $(TOOLS_BIN)
	cd tools && go build -o ../$(TOOLS_BIN)/golangci-lint github.com/golangci/golangci-lint/cmd/golangci-lint
[[ if .HasMigrations ]]
$(TOOLS_BIN)/goose: tools/go.mod tools/tools.go
	@mkdir -p $(TOOLS_BIN)
	cd tools && go build -o ../$(TOOLS_BIN)/goose github.com/pressly/goose/v3/cmd/goose
[[ end -]]
[[ if .HasDBTooling ]]
$(TOOLS_BIN)/sqlc: tools/go.mod tools/tools.go
	@mkdir -p $(TOOLS_BIN)
	cd tools && CGO_ENABLED=0 go build -o ../$(TOOLS_BIN)/sqlc github.com/sqlc-dev/sqlc/cmd/sqlc
[[ end ]]
[[ if .HasContainer ]]
## check-docker: verify docker is available
check-docker:
	@command -v docker >/dev/null 2>&1 || { echo "docker not found. Install from https://docs.docker.com/get-docker/"; exit 1; }
[[ end ]]
## help: show this help
help:
	@grep -E '^## ' $(MAKEFILE_LIST) | sed 's/## //' | column -t -s ':'
