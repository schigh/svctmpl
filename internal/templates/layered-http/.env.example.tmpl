# Service identity
SERVICE_NAME=[[ .ProjectName ]]
SERVICE_ENV=dev
[[ if .HasDatabase ]]
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=[[ .ProjectName ]]
DB_SSLMODE=disable
DB_MAX_CONNS=10

# Composite DSN used by goose (not read by the app directly)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/[[ .ProjectName ]]?sslmode=disable
[[ end ]]
# HTTP server
HTTP_PORT=8080
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=120s
[[ if .HasOTel ]]
# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=[[ .ProjectName ]]
OTEL_METRICS_PORT=9090
[[ end ]]