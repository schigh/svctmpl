# Database credentials for [[ .ProjectName ]].
#
# WARNING: Replace with real credentials or use a secrets manager
# (e.g. Sealed Secrets, External Secrets Operator, Vault).
#
# The values below are base64-encoded placeholders:
#   "postgres" -> cG9zdGdyZXM=
apiVersion: v1
kind: Secret
metadata:
  name: [[ .ProjectName ]]-secret
  namespace: [[ .ProjectName ]]
  labels:
    app: [[ .ProjectName ]]
type: Opaque
data:
  DB_USER: cG9zdGdyZXM=
  DB_PASSWORD: cG9zdGdyZXM=
