# Service identity
SERVICE_NAME=myservice
SERVICE_ENV=dev

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=myservice
DB_SSLMODE=disable
DB_MAX_CONNS=10

# Composite DSN used by goose (not read by the app directly)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/myservice?sslmode=disable

# HTTP server
HTTP_PORT=8080
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=120s

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=myservice
OTEL_METRICS_PORT=9090
